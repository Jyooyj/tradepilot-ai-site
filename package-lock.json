export default async function handler(req, res) {
  if (req.method !== "POST") {
    return res.status(405).json({ error: "Only POST is allowed" });
  }

  try {
    const { image, hint } = req.body || {};

    if (!image) {
      return res.status(400).json({ error: "缺少图片，请先上传产品图。" });
    }

    if (!process.env.DASHSCOPE_API_KEY) {
      return res.status(500).json({ error: "服务器未配置 DASHSCOPE_API_KEY。" });
    }

    const prompt = `
你是 TradePilot AI 的商品视觉识别与进货分析助手。

任务：请只根据上传图片识别商品，并补充适合进货判断的结构化信息。

非常重要的视觉判断规则：
1. 如果图片中是一整圈或半圈珍珠串、带扣头/延长链、放在首饰盒中，优先判断为“珍珠项链 / 珍珠锁骨链”，不要判断成耳夹、耳钉、耳环。
2. 只有当图片中明确出现一对小型耳饰、耳夹结构、耳钉针、夹扣，才可以判断为耳夹/耳饰。
3. 如果图片是发圈、头绳、大肠圈，判断为发饰。
4. 不要沿用页面旧字段，不要被示例产品影响。
5. 图片看不清时要保守输出，不要编造过细的名称。

用户补充线索：${hint || "无"}

请只输出严格 JSON，不要 Markdown，不要解释。格式如下：
{
  "product": {
    "name": "",
    "category": "",
    "material": "",
    "cost": "",
    "price": "",
    "moq": "",
    "audience": "",
    "channel": "",
    "supplier": "",
    "competitorPrice": "",
    "logistics": "",
    "keywords": "",
    "note": ""
  },
  "confidence": "高/中/低",
  "visualReason": "一句话说明为什么这么识别"
}

字段要求：
- name 必须是图片主体商品，不要把项链写成耳夹。
- cost 和 moq 如果图片无法判断，可以给进货场景的保守估算，但不要直接套用示例值。
- price 和 competitorPrice 可以给市场估算区间。
- keywords 用中文逗号分隔。
`;

    const response = await fetch("https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions", {
      method: "POST",
      headers: {
        Authorization: `Bearer ${process.env.DASHSCOPE_API_KEY}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        model: process.env.QWEN_VL_MODEL || "qwen3-vl-plus",
        messages: [
          {
            role: "user",
            content: [
              { type: "text", text: prompt },
              { type: "image_url", image_url: { url: image } },
            ],
          },
        ],
        temperature: 0,
      }),
    });

    const data = await response.json();

    if (!response.ok) {
      return res.status(response.status).json({
        error: data?.error?.message || data?.message || "阿里云百炼视觉模型调用失败",
        code: data?.error?.code || data?.code || "",
        detail: data,
      });
    }

    const rawText = data.choices?.[0]?.message?.content || "";
    const cleaned = rawText.replace(/```json/g, "").replace(/```/g, "").trim();

    let parsed;
    try {
      parsed = JSON.parse(cleaned);
    } catch (error) {
      return res.status(500).json({ error: "模型返回内容不是合法 JSON", raw: rawText });
    }

    return res.status(200).json(parsed);
  } catch (error) {
    return res.status(500).json({ error: "服务器处理失败", message: error.message });
  }
}
